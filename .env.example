# webhook-handler が使用する Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000000000/replace-with-token

# Docker Compose ネットワーク内で Mailpit が通知する Webhook 送信先
MP_WEBHOOK_URL=http://webhook-handler:8080/mail

# Discord 通知に表示する Mailpit Web UI の公開 URL
MAILPIT_PUBLIC_URL=http://localhost:8025
